# Vigil — AI-powered PR review
# Copy to .env and fill in the keys you need.

# GitHub personal access token (needs repo scope for PR access)
GITHUB_TOKEN=

# Model API keys — only need the one matching your --model choice
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Webhook server (for `vigil serve`)
WEBHOOK_SECRET=

# Email alerts for non-blocking specialists (e.g. Security)
# Leave blank to disable email alerts.
VIGIL_ALERT_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
